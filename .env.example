# Environment variables for Render deployment
# Copy this to .env and update values

# Backend Configuration
SPRING_DATASOURCE_URL=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# JWT Configuration
APP_JWT_SECRET=ExamPortalSecretKey2024CloudBasedNLPAutoEvaluationSystem
APP_JWT_EXPIRATION=86400000

# Service URLs (Render will auto-fill these)
NLP_SERVICE_URL=https://exam-nlp-service.onrender.com
APP_CORS_ALLOWED_ORIGINS=https://exam-frontend.onrender.com,https://exam-backend.onrender.com,http://localhost:3000

# Python NLP Service
PYTHONUNBUFFERED=true
DEBUG=false
PORT=8000
